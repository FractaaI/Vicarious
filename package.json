{
  "name": "vicarious",
  "private": true,
  "version": "0.1.0",
  "description": "A desktop writing space for visual novel dialogue.",
  "author": "Vicarious",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "preview": "electron-vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.1.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.vicarious.desktop",
    "productName": "Vicarious",
    "copyright": "Copyright 2026 Vicarious",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json",
      "!node_modules/**/*",
      "!demo.vicarious"
    ],
    "extraMetadata": {
      "main": "out/main/index.js"
    },
    "asar": true,
    "npmRebuild": false,
    "win": {
      "signAndEditExecutable": false,
      "forceCodeSigning": false,
      "target": [
        "dir"
      ]
    },
    "mac": {
      "identity": null,
      "target": [
        "dir"
      ]
    },
    "linux": {
      "target": [
        "dir"
      ]
    }
  }
}
